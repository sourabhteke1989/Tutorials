{
  "info": {
    "name": "CRUD Framework Demo",
    "description": "Complete Postman collection for testing the Generic CRUD Framework example application.\n\nDemo Users:\n- admin/admin — All permissions\n- editor/editor — Read + write (no delete)\n- viewer/viewer — Read only\n\nBase URL: http://localhost:8080",
    "_postman_id": "crud-framework-demo-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "admin" }
  ],
  "item": [
    {
      "name": "Health & Metadata",
      "item": [
        {
          "name": "Health Check (no auth)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/crud/health", "host": ["{{baseUrl}}"], "path": ["api", "crud", "health"] }
          }
        },
        {
          "name": "List Registered Entities",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/crud/entities", "host": ["{{baseUrl}}"], "path": ["api", "crud", "entities"] }
          }
        }
      ]
    },
