    {
      "name": "RBAC — Permission Tests",
      "item": [
        {
          "name": "Viewer: GET Product (expect 200)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "viewer", "type": "string" },
                { "key": "password", "value": "viewer", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entityType\": \"product\",\n  \"operation\": \"GET\",\n  \"id\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/crud", "host": ["{{baseUrl}}"], "path": ["api", "crud"] }
          }
        },
        {
          "name": "Viewer: CREATE Product (expect 403 — no write permission)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "viewer", "type": "string" },
                { "key": "password", "value": "viewer", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entityType\": \"product\",\n  \"operation\": \"CREATE\",\n  \"payload\": {\n    \"name\": \"Should Fail\",\n    \"price\": 10.00,\n    \"category\": \"Test\",\n    \"status\": \"active\",\n    \"stockQuantity\": 1\n  }\n}"
